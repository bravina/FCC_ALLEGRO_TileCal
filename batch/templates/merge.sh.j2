{% include '_env.sh.j2' %}

# --- Parameters ---
OUTPUT_DIR={{ output_dir }}
OUTPUT_FILE={{ output_file }}
LOCAL_OUT="/tmp/${USER}/merge/${OUTPUT_FILE}"

mkdir -p "/tmp/${USER}/merge"

INPUT_FILES=(
{% for f in input_files %}
