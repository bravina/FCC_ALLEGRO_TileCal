#!/bin/bash
# Auto-generated by submit.py — do not edit by hand
# Merge job: {{ sample_name }}_ecm{{ ecm }}
set -euo pipefail

# --- Environment ---
# hadd is part of ROOT, available after sourcing Key4hep
{% if key4hep_setup == "latest" %}
source /cvmfs/sw-nightlies.hsf.org/key4hep/setup.sh
{% else %}
source /cvmfs/sw-nightlies.hsf.org/key4hep/setup.sh -r {{ key4hep_setup }}
{% endif %}

# --- Parameters ---
OUTPUT_DIR={{ output_dir }}
OUTPUT_FILE={{ output_file }}

mkdir -p "${OUTPUT_DIR}"

# Input files passed as positional arguments
INPUT_FILES=(
{% for f in input_files %}
  "{{ f }}"
{% endfor %}
)

hadd -f "${OUTPUT_DIR}/${OUTPUT_FILE}" "${INPUT_FILES[@]}"

echo "MERGE done: ${OUTPUT_DIR}/${OUTPUT_FILE}"
