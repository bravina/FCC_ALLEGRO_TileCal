#!/bin/bash
# Auto-generated by submit.py — do not edit by hand
# CaloNtupleizer job: {{ sample_name }}_ecm{{ ecm }}

{% include '_env.sh.j2' %}

# --- Parameters ---
OUTPUT_DIR={{ output_dir }}
OUTPUT_FILE={{ output_file }}
LOCAL_OUT="/tmp/${USER}/ntuple/${OUTPUT_FILE}"

mkdir -p "/tmp/${USER}/ntuple"

INPUT_FILES=(
{% for f in input_files %}
  "{{ f }}"
{% endfor %}
)

calo-ntupleizer \
  --inputFiles  "${INPUT_FILES[@]}" \
  --outputDir   "/tmp/${USER}/ntuple" \
  --outputFile  "${OUTPUT_FILE}" \
  -geometryFile "${ALLEGRO_COMPACT}"
rc=$?; if [ $rc -ne 0 ]; then echo "ERROR: calo-ntupleizer failed (exit $rc)"; exit $rc; fi

eos_cp "${LOCAL_OUT}" "${OUTPUT_DIR}/${OUTPUT_FILE}"
echo "NTUPLE done: ${OUTPUT_DIR}/${OUTPUT_FILE}"