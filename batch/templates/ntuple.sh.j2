#!/bin/bash
# Auto-generated by submit.py — do not edit by hand
# CaloNtupleizer job: {{ sample_name }}_ecm{{ ecm }}
set -euo pipefail

# --- Environment ---
{% if key4hep_setup == "latest" %}
source /cvmfs/sw-nightlies.hsf.org/key4hep/setup.sh
{% else %}
source /cvmfs/sw-nightlies.hsf.org/key4hep/setup.sh -r {{ key4hep_setup }}
{% endif %}
source {{ workdir }}/setup.sh

# --- Parameters ---
OUTPUT_DIR={{ output_dir }}
OUTPUT_FILE={{ output_file }}

mkdir -p "${OUTPUT_DIR}"

# Input files passed as positional arguments
INPUT_FILES=(
{% for f in input_files %}
  "{{ f }}"
{% endfor %}
)

calo-ntupleizer \
  --inputFiles  "${INPUT_FILES[@]}" \
  --outputFile  "${OUTPUT_DIR}/${OUTPUT_FILE}"

echo "NTUPLE done: ${OUTPUT_DIR}/${OUTPUT_FILE}"
