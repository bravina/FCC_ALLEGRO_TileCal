#!/bin/bash
# Auto-generated by submit.py — do not edit by hand
# Simulation job: {{ sample_name }}_ecm{{ ecm }}  job {{ job_index }}
set -euo pipefail

# --- Environment ---
WORKDIR={{ workdir }}
{% if key4hep_setup == "latest" %}
source /cvmfs/sw-nightlies.hsf.org/key4hep/setup.sh
{% else %}
source /cvmfs/sw-nightlies.hsf.org/key4hep/setup.sh -r {{ key4hep_setup }}
{% endif %}
source {{ workdir }}/setup.sh

# --- Parameters ---
INPUT_FILE={{ hepmc_file }}
OUTPUT_DIR={{ output_dir }}
OUTPUT_FILE={{ output_file }}
NEVENTS={{ nevents }}
SKIP={{ skip_events }}
SEED={{ seed }}

mkdir -p "${OUTPUT_DIR}"

# --- Run ddsim ---
ddsim \
  --inputFiles     "${INPUT_FILE}" \
  --numberOfEvents "${NEVENTS}" \
  --skipNEvents    "${SKIP}" \
  --outputFile     "${OUTPUT_DIR}/${OUTPUT_FILE}" \
  --random.enableEventSeed \
  --random.seed    "${SEED}" \
  --compactFile    "${ALLEGRO_COMPACT}"

echo "SIM done: ${OUTPUT_DIR}/${OUTPUT_FILE}"
