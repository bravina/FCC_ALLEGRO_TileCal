# Auto-generated by submit.py — do not edit by hand
# HTCondor submit file for: {{ job_name }}
universe                = vanilla
executable              = {{ script }}
output                  = {{ log_dir }}/{{ job_name }}.$(ClusterId).$(ProcId).out
error                   = {{ log_dir }}/{{ job_name }}.$(ClusterId).$(ProcId).err
log                     = {{ log_dir }}/{{ job_name }}.$(ClusterId).log
+JobFlavour             = "{{ job_flavour }}"
request_memory          = {{ request_memory_mb }}
+AccountingGroup         = "group_u_FCC.local_gen"
getenv                  = False
should_transfer_files   = YES
when_to_transfer_output = ON_EXIT
queue
