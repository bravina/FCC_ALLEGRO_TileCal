#!/bin/bash
# Auto-generated by submit.py — do not edit by hand
# Generation job: {{ sample_name }}_ecm{{ ecm }}  job {{ job_index }}

{% include '_env.sh.j2' %}

# --- Parameters ---
CARD={{ card }}
OUTPUT_DIR={{ output_dir }}
OUTPUT_FILE={{ output_file }}   # basename without .hepmc
NEVENTS={{ nevents }}
SEED={{ seed }}
ECM={{ ecm }}

mkdir -p /tmp/${USER}/gen

pythia \
  --card    "${CARD}" \
  --ecm     "${ECM}" \
  --seed    "${SEED}" \
  --nevents "${NEVENTS}" \
  --output  "/tmp/${USER}/gen/${OUTPUT_FILE}"
rc=$?; if [ $rc -ne 0 ]; then echo "ERROR: pythia failed (exit $rc)"; exit $rc; fi

eos_cp "/tmp/${USER}/gen/${OUTPUT_FILE}.hepmc" "${OUTPUT_DIR}/${OUTPUT_FILE}.hepmc"
echo "GEN done: ${OUTPUT_DIR}/${OUTPUT_FILE}.hepmc"