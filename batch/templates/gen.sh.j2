#!/bin/bash
# Auto-generated by submit.py — do not edit by hand
# Generation job: {{ sample_name }}_ecm{{ ecm }}  job {{ job_index }}
set -euo pipefail

# --- Environment ---
WORKDIR={{ workdir }}
{% if key4hep_setup == "latest" %}
source /cvmfs/sw-nightlies.hsf.org/key4hep/setup.sh
{% else %}
source /cvmfs/sw-nightlies.hsf.org/key4hep/setup.sh -r {{ key4hep_setup }}
{% endif %}
source {{ workdir }}/setup.sh

# --- Parameters ---
CARD={{ workdir }}/{{ card }}
OUTPUT_DIR={{ output_dir }}
OUTPUT_FILE={{ output_file }}   # basename without .hepmc
NEVENTS={{ nevents }}
SEED={{ seed }}
ECM={{ ecm }}

mkdir -p "${OUTPUT_DIR}"

# --- Run Pythia8 ---
pythia \
  --card  "${CARD}" \
  --ecm   "${ECM}" \
  --seed  "${SEED}" \
  --nevents "${NEVENTS}" \
  --output  "${OUTPUT_DIR}/${OUTPUT_FILE}"

echo "GEN done: ${OUTPUT_DIR}/${OUTPUT_FILE}.hepmc"
