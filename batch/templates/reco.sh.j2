#!/bin/bash
# Auto-generated by submit.py — do not edit by hand
# Reconstruction job: {{ sample_name }}_ecm{{ ecm }}  job {{ job_index }}

{% include '_env.sh.j2' %}

# --- Parameters ---
INPUT_FILES=(
{% for f in sim_files %}
  "{{ f }}"
{% endfor %}
)
OUTPUT_DIR={{ output_dir }}
OUTPUT_FILE={{ output_file }}
LOCAL_OUT="/tmp/${USER}/reco/${OUTPUT_FILE}"

mkdir -p "/tmp/${USER}/reco"

cd {{ rundir }}

k4run run_reco_pandora.py \
  --pandoraSettings "{{ pandora_settings }}" \
  --IOSvc.Input     "${INPUT_FILES[@]}" \
  --IOSvc.Output    "${LOCAL_OUT}"
rc=$?; if [ $rc -ne 0 ]; then echo "ERROR: k4run failed (exit $rc)"; exit $rc; fi

eos_cp "${LOCAL_OUT}" "${OUTPUT_DIR}/${OUTPUT_FILE}"
echo "RECO done: ${OUTPUT_DIR}/${OUTPUT_FILE}"